{
  "entities": {
    "Terminal": {
      "title": "Terminal",
      "description": "Terminal profile details including model, serial number, and status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "model": { "type": "string" },
        "serialNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["На складе", "В кабинете", "В ремонте"] },
        "createdAt": { "type": "string" },
        "warrantyEndsAt": { "type": "string" }
      },
      "required": ["id", "model", "serialNumber", "status", "createdAt"]
    },
    "HistoryEntry": {
      "title": "HistoryEntry",
      "description": "Historical log of terminal movements, repairs, and assignments.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "terminalId": { "type": "string" },
        "model": { "type": "string" },
        "serialNumber": { "type": "string" },
        "malfunction": { "type": "string" },
        "dateToIT": { "type": "string" },
        "dateToSC": { "type": "string" },
        "repairedBy": { "type": "string" },
        "dateFromRepair": { "type": "string" },
        "dateToWarehouse": { "type": "string" },
        "rc": { "type": "string" },
        "zno": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "terminalId", "model", "serialNumber", "createdAt"]
    },
    "Instruction": {
      "title": "Instruction",
      "description": "Guide or manual for terminals configuration or logistics.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "title", "content", "category", "createdAt"]
    },
    "PortalNews": {
      "title": "PortalNews",
      "description": "Company news item with title, text content, and optional image.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string" },
        "author": { "type": "string" }
      },
      "required": ["id", "title", "content", "createdAt"]
    },
    "PortalLink": {
      "title": "PortalLink",
      "description": "Useful links directory for the logistics hub.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["id", "title", "url"]
    },
    "PortalTask": {
      "title": "PortalTask",
      "description": "Tasks and reminders for the warehouse team.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string" },
        "completed": { "type": "boolean" },
        "priority": { "type": "string", "enum": ["Низкий", "Средний", "Высокий", "Терміново"] },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "title", "completed", "priority", "createdAt"]
    },
    "PortalSettings": {
      "title": "PortalSettings",
      "description": "Configuration settings for the portal like shift schedule link and air raid overrides.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "scheduleUrl": { "type": "string" },
        "activeAlertRegion": { "type": "string" },
        "alertActive": { "type": "boolean" }
      },
      "required": ["id"]
    }
  },
  "firestore": {
    "/terminals/{terminalId}": {
      "schema": "Terminal",
      "description": "Collection of terminal devices."
    },
    "/history/{historyId}": {
      "schema": "HistoryEntry",
      "description": "History of terminal repairs and movements."
    },
    "/instructions/{instructionId}": {
      "schema": "Instruction",
      "description": "Knowledge base articles and instructions."
    },
    "/portal_news/{newsId}": {
      "schema": "PortalNews",
      "description": "Team news and posts on the portal."
    },
    "/portal_links/{linkId}": {
      "schema": "PortalLink",
      "description": "Useful reference links on the portal."
    },
    "/portal_tasks/{taskId}": {
      "schema": "PortalTask",
      "description": "Team checklists and tasks on the portal."
    },
    "/portal_settings/{settingsId}": {
      "schema": "PortalSettings",
      "description": "Global settings for the portal dashboard."
    }
  }
}
